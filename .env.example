# Copy to .env on the server (next to docker-compose.yml).
# Never commit the real .env.

# Postgres user password — pre-create the user via:
#   psql -h central-pgbouncer -U postgres -c "CREATE USER rss_user WITH PASSWORD '...';"
#   psql -h central-pgbouncer -U postgres -c "CREATE DATABASE rss_fresh OWNER rss_user;"
DB_PASSWORD=

# 64+ random chars. Used to gate /api/v1/news/summary.
# Generate: openssl rand -base64 48
OPENCLAW_GATEWAY_TOKEN=

# Optional: leave empty to disable Telegram entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=0

# Tuning. The defaults are sane.
FETCH_CRON=*/15 * * * *
FETCH_BATCH_SIZE=10
FETCH_TIMEOUT_SECONDS=20
DIGEST_CRON=0 8 * * *

LOG_LEVEL=info
TZ=Europe/Istanbul
